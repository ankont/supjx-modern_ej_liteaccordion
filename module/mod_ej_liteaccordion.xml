  <authorEmail>ankont@sch.gr</authorEmail>
  <authorUrl>superor.wordpress.com</authorUrl>
  <version>2.0.0</version>
  <description>
    <![CDATA[
    <div class="ej_description">
      <span class="ej_title">EJ LiteAccordion Module</span>
      <span class="ej_subtitle">
        Ported for J4 by <b>Andreas Kontarinis</b>, with assistance from <b><i>ChatGPT</i></b> and <b><i>Gemini</i></b>. Original J3 module by <b>Element J</b> (original module website dead).
      </span>
      <p>
        The EJ LiteAccordion module displays your images in the slick jQuery
        based LiteAccordion Slider (
        <a href="http://nicolahibbert.com/demo/liteAccordion/" target="_blank">
          http://nicolahibbert.com/demo/liteAccordion/
        </a>
        ). Images are pulled dynamically from your site content and are
        automatically resized to the dimensions you specify. Titles and
        Captions can be drawn from your content. Linking to your Joomla content
        is also supported!
      </p>
    </div>
    ]]>
  </description>

	<languages folder="language">
        <language tag="en-GB">en-GB/mod_ej_liteaccordion.ini</language>
        <language tag="en-GB">en-GB/mod_ej_liteaccordion.sys.ini</language>
        <language tag="el-GR">el-GR/mod_ej_liteaccordion.ini</language>
        <language tag="el-GR">el-GR/mod_ej_liteaccordion.sys.ini</language>
